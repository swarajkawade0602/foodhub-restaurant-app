pipeline {
    agent any

    environment {
        SSH_CRED    = 'node-app-key'                  
        SERVER_IP   = '172.31.46.238'                    
        REMOTE_USER = 'ubuntu'
        WEB_DIR     = '/var/www/html/foodhub'
    }

    stages {

        stage('Clone Repo') {
            steps {
                git url: 'https://github.com/swarajkawade0602/foodhub-restaurant-app.git', branch: 'master'
            }
        }

        stage('Deploy to Nginx Server') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                        echo "Cleaning old files on server..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "sudo rm -rf ${WEB_DIR}/*"

                        echo "Uploading new files to /tmp on server..."
                        scp -o StrictHostKeyChecking=no index.html style.css contact.html about.html menu.html ${REMOTE_USER}@${SERVER_IP}:/tmp/

                        echo "Deploying files to Nginx web directory..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "sudo cp /tmp/index.html /tmp/style.css /tmp/contact.html /tmp/about.html /tmp/menu.html ${WEB_DIR}/"
                    '''
                }
            }
        }
    }
}